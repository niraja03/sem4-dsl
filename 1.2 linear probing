#include <iostream>
using namespace std;

class HashLinear {
    int size;
    int id[10];
    int qty[10];

public:
    HashLinear(int s) {
        size = s;
        for(int i = 0; i < size; i++) {
            id[i] = -1;   // empty slot
        }
    }

    int hash(int key) {
        return key % size;
    }

    void insert(int key, int q) {
        int index = hash(key);

        while(id[index] != -1) {   // collision
            index = (index + 1) % size; // linear probing
        }

        id[index] = key;
        qty[index] = q;
    }

    void search(int key) {
        int index = hash(key);

        while(id[index] != -1) {
            if(id[index] == key) {
                cout << "Found ID " << key << " with Qty " << qty[index] << endl;
                return;
            }
            index = (index + 1) % size;
        }

        cout << "ID not found\n";
    }

    void display() {
        for(int i = 0; i < size; i++) {
            if(id[i] != -1)
                cout << i << " -> ID: " << id[i] << ", Qty: " << qty[i] << endl;
            else
                cout << i << " -> Empty\n";
        }
    }
};

int main() {
    HashLinear h(5);
    int choice, id, qty;

    do {
        cout << "\n1.Insert\n2.Search\n3.Display\n4.Exit\n";
        cin >> choice;

        switch(choice) {
            case 1:
                cout << "Enter ID: ";
                cin >> id;
                cout << "Enter Qty: ";
                cin >> qty;
                h.insert(id, qty);
                break;

            case 2:
                cout << "Enter ID to search: ";
                cin >> id;
                h.search(id);
                break;

            case 3:
                h.display();
                break;
        }
    } while(choice != 4);

    return 0;
}