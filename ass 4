#include<iostream>
#include<queue>
using namespace std;

int graph[10][10], visited[10];
int n;

// Print graph
void printGraph()
{
    cout<<"\nAdjacency Matrix of Graph:\n";
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n;j++)
        {
            cout<<graph[i][j]<<" ";
        }
        cout<<endl;
    }

    cout<<"\nEdges of Graph:\n";
    for(int i=1;i<=n;i++)
    {
        for(int j=i+1;j<=n;j++)
        {
            if(graph[i][j]==1)
                cout<<i<<" -- "<<j<<endl;
        }
    }
}

// BFS
void bfs(int start)
{
    queue<int> q;
    cout<<"\nBFS Traversal: ";

    q.push(start);
    visited[start]=1;

    while(!q.empty())
    {
        int v=q.front();
        q.pop();

        cout<<v<<" ";

        for(int i=1;i<=n;i++)
        {
            if(graph[v][i]==1 && visited[i]==0)
            {
                q.push(i);
                visited[i]=1;
            }
        }
    }
}

// DFS
void dfs(int v)
{
    cout<<v<<" ";
    visited[v]=1;

    for(int i=1;i<=n;i++)
    {
        if(graph[v][i]==1 && visited[i]==0)
        {
            dfs(i);
        }
    }
}

int main()
{
    int start;

    cout<<"Enter number of vertices: ";
    cin>>n;

    cout<<"Enter adjacency matrix:\n";
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=n;j++)
        {
            cin>>graph[i][j];
        }
    }

    printGraph();

    cout<<"\nEnter starting vertex: ";
    cin>>start;

    for(int i=1;i<=n;i++)
        visited[i]=0;
    bfs(start);

    for(int i=1;i<=n;i++)
        visited[i]=0;
    cout<<"\nDFS Traversal: ";
    dfs(start);

    return 0;
}